<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>Lextm.SharpSnmpLib</id>
    <version>12.5.7</version>
    <title>#SNMP Library</title>
    <authors>Malcolm Crowe,Lex Li,and other contributors.</authors>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>readme.md</readme>
    <projectUrl>https://docs.sharpsnmp.com/</projectUrl>
    <description>#SNMP (SharpSNMP) Library is an open source library for developers who target Microsoft .NET platforms. It's developed in C# and can be used for F#, VB.NET, Oxygene, and more.</description>
    <releaseNotes>https://github.com/lextudio/sharpsnmplib/releases</releaseNotes>
    <copyright>Copyright (c) 2008-2024 Malcolm Crowe, Lex Li, and other contributors.</copyright>
    <tags>smi snmp mib</tags>
    <repository type="git" url="https://github.com/lextudio/sharpsnmplib.git" branch="master" commit="6f6937b81e6bb14dae890c8ee7e0642323907d33" />
    <dependencies>
      <group targetFramework=".NETFramework4.7.1" />
      <group targetFramework="net8.0" />
    </dependencies>
    <frameworkAssemblies>
      <frameworkAssembly assemblyName="System.Configuration" targetFramework=".NETFramework4.7.1" />
    </frameworkAssemblies>
  </metadata>
</package>