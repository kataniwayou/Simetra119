{
  "Otlp": {
    "Endpoint": "http://otel-collector:4317",
    "ServiceName": "snmp-collector"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    },
    "EnableConsole": false
  },
  "CorrelationJob": {
    "IntervalSeconds": 30
  },
  "SnmpHeartbeatJob": {
    "IntervalSeconds": 15
  },
  "Liveness": {
    "GraceMultiplier": 2.0
  },
  "SnapshotJob": {
    "IntervalSeconds": 15,
    "TimeoutMultiplier": 0.8
  },
  "PreferredHeartbeatJob": {
    "IntervalSeconds": 15
  },
  "Devices": [],
  "OidMap": {},
  "SnmpListener": {
    "BindAddress": "0.0.0.0",
    "Port": 162
  },
  "Lease": {
    "Name": "snmp-collector-leader",
    "Namespace": "default",
    "DurationSeconds": 15,
    "RenewIntervalSeconds": 10
  }
}
